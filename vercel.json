
{
    "redirects": [
        {
            "source": "/essay/",
            "destination": "/logs/",
            "permanent": true
        }
    ],
    "git": {
        "deploymentEnabled": {
            "test": false
        }
    },
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                }
            ]
        }
    ],
    "cleanUrls": true
}